import asyncio
import time
import threading
import re
from typing import Optional, Dict, Any

import httpx
import serial
from fastapi import FastAPI, WebSocket
from fastapi.responses import HTMLResponse, JSONResponse
from pydantic import BaseModel, Field

# =========================
# CONFIG
# =========================

PORT = "/dev/serial/by-id/usb-Silicon_Labs_CP2102_USB_to_UART_Bridge_Controller_Y10162-if00-port0"
BAUD = 9600

OPEN_METEO_URL = "https://api.open-meteo.com/v1/forecast?latitude=41.93&longitude=-73.91&current_weather=true"

DEFAULT_LOCATION_LABEL = "GoLab"
DEFAULT_LOCATION_ID = 1
DEFAULT_SAMPLE_TIME_S = 10
DEFAULT_HOLD_TIME_S = 50
DEFAULT_SAMPLES = 480

app = FastAPI()

# =========================
# RUN SETTINGS MODEL
# =========================

class RunSettings(BaseModel):
    location: str = Field(default=DEFAULT_LOCATION_LABEL, min_length=1, max_length=64)  # UI only
    location_id: int = Field(default=DEFAULT_LOCATION_ID, ge=1, le=999)

    sample_time_s: int = Field(default=DEFAULT_SAMPLE_TIME_S, ge=1, le=9999)
    hold_time_s: int = Field(default=DEFAULT_HOLD_TIME_S, ge=0, le=9999)
    samples: int = Field(default=DEFAULT_SAMPLES, ge=1, le=999)

current_settings = RunSettings()

# =========================
# LATEST READING (in-memory)
# =========================

latest_lock = threading.Lock()
latest_reading: Optional[Dict[str, Any]] = None
# Example:
# {
#   "ts": "2026-02-16 16:11:28",
#   "count_0p3": 187320,
#   "count_5p0": 0
# }

# =========================
# GT-521S CONTROLLER
# =========================

class GT521:
    def __init__(self):
        self.ser: Optional[serial.Serial] = None
        self.lock = threading.Lock()

        self.reader_thread: Optional[threading.Thread] = None
        self.reader_stop = threading.Event()
        self.reader_running = False

    def open(self):
        if self.ser and self.ser.is_open:
            return

        self.ser = serial.Serial(
            PORT,
            BAUD,
            timeout=0,   # non-blocking
            xonxoff=False,
            rtscts=False,
            dsrdtr=False,
        )

        try:
            self.ser.dtr = True
            self.ser.rts = True
        except Exception:
            pass

        time.sleep(1.0)
        self.ser.reset_input_buffer()

    def _read_for(self, seconds=1.0) -> bytes:
        end = time.time() + seconds
        out = b""
        while time.time() < end:
            n = self.ser.in_waiting if self.ser else 0
            if n:
                out += self.ser.read(n)
            else:
                time.sleep(0.02)
        return out

    def _poke_until_star(self) -> bytes:
        seen = b""
        if not self.ser:
            return seen
        for _ in range(12):
            self.ser.write(b"\r")
            self.ser.flush()
            time.sleep(0.08)
            chunk = self._read_for(0.6)
            if chunk:
                seen += chunk
                if b"*" in chunk:
                    return seen
        return seen

    def send_line(self, line: bytes, read_seconds: float = 1.2) -> tuple[bool, bytes]:
        """
        Send command (CR terminated) and collect some response.
        ok=True means we saw a '*' prompt (device responsive).
        """
        if not self.ser:
            return False, b"(serial not open)"

        all_seen = b""
        for _ in range(3):
            all_seen += self._poke_until_star()

            self.ser.reset_input_buffer()
            self.ser.write(line + b"\r")
            self.ser.flush()
            time.sleep(0.12)

            resp = self._read_for(read_seconds)
            all_seen += resp

            if b"*" in resp:
                return True, all_seen

            all_seen += self._poke_until_star()

        return (b"*" in all_seen), all_seen

    # ---- basic ----
    def start(self): return self.send_line(b"S", read_seconds=0.9)
    def stop(self):  return self.send_line(b"E", read_seconds=0.9)
    def op_status(self): return self.send_line(b"OP", read_seconds=0.9)

    # ---- settings ----
    def set_location_id(self, loc_id: int): return self.send_line(f"ID {loc_id:03d}".encode(), read_seconds=0.9)
    def set_sample_time(self, sec: int):    return self.send_line(f"ST {sec:04d}".encode(), read_seconds=0.9)
    def set_hold_time(self, sec: int):      return self.send_line(f"SH {sec:04d}".encode(), read_seconds=0.9)
    def set_samples(self, n: int):          return self.send_line(f"SN {n:03d}".encode(), read_seconds=0.9)

    def read_settings_report(self) -> tuple[bool, str]:
        """
        Ask for the Settings Report and return text.
        We read a bit longer because the report is multi-line.
        """
        ok, raw = self.send_line(b"1", read_seconds=2.0)
        return ok, raw.decode(errors="replace")

    # =========================
    # Reader thread: parse CSV measurement lines
    # =========================

    @staticmethod
    def _parse_measurement_line(line: str):
        line = line.strip()
        if not line:
            return None

        line = line.lstrip("*").strip()

        if not re.match(r"^\d{4}-\d{2}-\d{2} \d{2}:\d{2}:\d{2},", line):
            return None

        if "*" in line:
            line = line.split("*", 1)[0].strip().rstrip(",")

        parts = [p.strip() for p in line.split(",")]
        if len(parts) < 5:
            return None

        ts = parts[0]

        try:
            size1 = float(parts[1]); cnt1 = int(parts[2])
            size2 = float(parts[3]); cnt2 = int(parts[4])
        except:
            return None

        out = {"ts": ts}

        if abs(size1 - 0.3) < 0.11:
            out["count_0p3"] = cnt1
        if abs(size1 - 5.0) < 0.11:
            out["count_5p0"] = cnt1
        if abs(size2 - 0.3) < 0.11:
            out["count_0p3"] = cnt2
        if abs(size2 - 5.0) < 0.11:
            out["count_5p0"] = cnt2

        return out


    def _reader_loop(self):
        """
        Continuously read bytes, split into lines, parse measurement lines.
        """
        buf = b""
        self.reader_running = True
        try:
            while not self.reader_stop.is_set():
                if not self.ser:
                    time.sleep(0.1)
                    continue

                n = self.ser.in_waiting
                if n:
                    buf += self.ser.read(n)
                    # Split on CR/LF boundaries
                    while b"\n" in buf:
                        line, buf = buf.split(b"\n", 1)
                        s = line.decode(errors="replace").strip()
                        parsed = self._parse_measurement_line(s)
                        if parsed:
                            with latest_lock:
                                global latest_reading
                                latest_reading = parsed
                else:
                    time.sleep(0.05)
        finally:
            self.reader_running = False

    def ensure_reader(self):
        """
        Make sure the background reader is running.
        Safe to call repeatedly.
        """
        if self.reader_thread and self.reader_thread.is_alive():
            return
        self.reader_stop.clear()
        self.reader_thread = threading.Thread(target=self._reader_loop, daemon=True)
        self.reader_thread.start()

    def stop_reader(self):
        self.reader_stop.set()
        # Don't join hard; just let daemon thread exit.

gt = GT521()

# =========================
# Helpers: parse settings report
# =========================

def parse_settings_report(text: str) -> dict:
    def pick_int(label: str):
        m = re.search(
            rf"^\s*{re.escape(label)}\s*,\s*(\d+)",
            text,
            flags=re.MULTILINE
        )
        return int(m.group(1)) if m else None

    return {
        "location_id": pick_int("Location"),
        "sample_time_s": pick_int("Sample Time"),
        "hold_time_s": pick_int("Hold Time"),
        "samples": pick_int("Samples"),
    }

# =========================
# DASHBOARD UI
# =========================

@app.get("/", response_class=HTMLResponse)
def dashboard():
    s = current_settings
    return f"""
    <html>
    <head>
        <title>GoLab Monitor</title>
        <style>
            body {{ font-family: system-ui; padding: 30px; max-width: 980px; }}
            label {{ display:block; margin-top: 12px; font-weight: 600; }}
            input {{ font-size: 16px; padding: 8px; width: 260px; }}
            .row {{ display:flex; gap: 30px; flex-wrap: wrap; align-items: flex-start; }}
            .card {{ padding: 16px; border: 1px solid #ddd; border-radius: 10px; }}
            button {{ font-size: 18px; padding: 10px 16px; margin-right: 10px; cursor: pointer; }}
            pre {{ background: #f3f3f3; padding: 12px; border-radius: 8px; white-space: pre-wrap; }}
            .muted {{ color:#666; }}
            .small {{ font-size: 13px; }}
            .ok {{ color: #0a7; font-weight: 700; }}
            .bad {{ color: #c22; font-weight: 700; }}
            table {{ border-collapse: collapse; }}
            td {{ padding: 6px 10px; border-bottom: 1px solid #eee; }}
        </style>
    </head>
    <body>
        <h1>GT-521S</h1>

        <div class="row">
          <div class="card">
            <h3>Run settings</h3>

            <label>Location label (UI only)</label>
            <input id="location" type="text" value="{s.location}"/>

            <label>Location ID (GT LCD)</label>
            <input id="location_id" type="number" min="1" max="999" value="{s.location_id}"/>

            <label>Sample Time (seconds)</label>
            <input id="sample_time_s" type="number" min="1" max="9999" value="{s.sample_time_s}"/>

            <label>Hold Time (seconds)</label>
            <input id="hold_time_s" type="number" min="0" max="9999" value="{s.hold_time_s}"/>

            <label>Samples (1–999)</label>
            <input id="samples" type="number" min="1" max="999" value="{s.samples}"/>

            <p class="muted small" style="margin-top:12px;">
              Start applies settings to the GT, then begins sampling.
            </p>

            <p>
              <button onclick="startRun()">Start</button>
              <button onclick="stopRun()">Stop</button>
            </p>

            <div id="confirm" class="small muted">No action yet.</div>
          </div>

          <div class="card" style="min-width:360px;">
            <h3>Computed</h3>
            <div><b>Cycle time:</b> <span id="cycle">-</span> sec</div>
            <div><b>Expected duration:</b> <span id="duration">-</span></div>

            <h3 style="margin-top:18px;">Latest reading</h3>
            <table>
              <tr><td><b>Timestamp</b></td><td id="r_ts">—</td></tr>
              <tr><td><b>0.3 µm</b></td><td id="r_03">—</td></tr>
              <tr><td><b>5.0 µm</b></td><td id="r_50">—</td></tr>
            </table>

            <div class="muted small" style="margin-top:10px;">
              Updates automatically while running.
            </div>
          </div>
        </div>

        <script>
            function getSettings() {{
              return {{
                location: document.getElementById("location").value.trim() || "GoLab",
                location_id: parseInt(document.getElementById("location_id").value || "1"),
                sample_time_s: parseInt(document.getElementById("sample_time_s").value || "10"),
                hold_time_s: parseInt(document.getElementById("hold_time_s").value || "50"),
                samples: parseInt(document.getElementById("samples").value || "480"),
              }};
            }}

            function fmtDuration(totalSeconds) {{
              const s = Math.max(0, Math.floor(totalSeconds));
              const h = Math.floor(s / 3600);
              const m = Math.floor((s % 3600) / 60);
              const r = s % 60;
              return `${{h}}h ${{m}}m ${{r}}s`;
            }}

            function updateComputed() {{
              const s = getSettings();
              const cycle = s.sample_time_s + s.hold_time_s;
              const total = cycle * s.samples;
              document.getElementById("cycle").textContent = cycle.toString();
              document.getElementById("duration").textContent = fmtDuration(total);
            }}

            ["location","location_id","sample_time_s","hold_time_s","samples"].forEach(id => {{
              document.getElementById(id).addEventListener("input", updateComputed);
            }});
            updateComputed();

            async function startRun() {{
                const c = document.getElementById("confirm");
                c.className = "small muted";
                c.textContent = "Applying settings...";
                const settings = getSettings();
                const r = await fetch("/gt/start", {{
                  method: "POST",
                  headers: {{ "Content-Type": "application/json" }},
                  body: JSON.stringify(settings),
                }});
                const j = await r.json();

                if (j.ok) {{
                  c.className = "small ok";
                  c.textContent = `Applied @ ${{j.applied_at}}  |  ID=${{j.applied.location_id}}, ST=${{j.applied.sample_time_s}}, SH=${{j.applied.hold_time_s}}, SN=${{j.applied.samples}}`;
                }} else {{
                  c.className = "small bad";
                  c.textContent = `Apply FAILED @ ${{j.applied_at}}  | mismatch: ${{JSON.stringify(j.mismatch)}}`;
                }}
            }}

            async function stopRun() {{
                const c = document.getElementById("confirm");
                c.className = "small muted";
                c.textContent = "Stopping...";
                const r = await fetch("/gt/stop", {{method: "POST"}});
                const j = await r.json();
                c.className = j.ok ? "small ok" : "small bad";
                c.textContent = j.ok ? `Stopped @ ${{j.at}}` : `Stop failed @ ${{j.at}}`;
            }}

            async function pollLatest() {{
              try {{
                const r = await fetch("/gt/latest");
                const j = await r.json();
                if (j && j.latest) {{
                  document.getElementById("r_ts").textContent = j.latest.ts ?? "—";
                  document.getElementById("r_03").textContent = (j.latest.count_0p3 ?? "—").toString();
                  document.getElementById("r_50").textContent = (j.latest.count_5p0 ?? "—").toString();
                }}
              }} catch (e) {{
                // ignore
              }}
            }}

            setInterval(pollLatest, 1000);
            pollLatest();
        </script>
    </body>
    </html>
    """

# =========================
# CONTROL ENDPOINTS (clean output)
# =========================

@app.get("/gt/debug/raw")
def debug_raw():
    with gt.debug_lock:
        s = gt.debug_last_bytes.decode(errors="replace")
    return JSONResponse({"raw_tail": s})

@app.post("/gt/start")
def start(settings: RunSettings):
    global current_settings
    current_settings = settings

    applied_at = time.strftime("%Y-%m-%d %H:%M:%S")

    with gt.lock:
        gt.open()

        # Always stop before applying settings
        gt.stop()
        time.sleep(0.2)

        # Apply settings (zero-padded)
        gt.set_location_id(settings.location_id)
        gt.set_sample_time(settings.sample_time_s)
        gt.set_hold_time(settings.hold_time_s)
        gt.set_samples(settings.samples)

        # Verify by readback
        ok_rb, report = gt.read_settings_report()
        applied = parse_settings_report(report)

        wanted = {
            "location_id": settings.location_id,
            "sample_time_s": settings.sample_time_s,
            "hold_time_s": settings.hold_time_s,
            "samples": settings.samples,
        }
        mismatch = {
            k: {"wanted": wanted[k], "got": applied.get(k)}
            for k in wanted
            if applied.get(k) != wanted[k]
        }

        # Start sampling
        gt.start()

        # Start background reader to capture measurement lines
        gt.ensure_reader()

    ok = ok_rb and (len(mismatch) == 0)

    return JSONResponse({
        "ok": ok,
        "applied_at": applied_at,
        "requested": wanted,
        "applied": applied,
        "mismatch": mismatch,
        "expected_cycle_s": settings.sample_time_s + settings.hold_time_s,
        "expected_duration_s": (settings.sample_time_s + settings.hold_time_s) * settings.samples,
    })

@app.post("/gt/stop")
def stop():
    at = time.strftime("%Y-%m-%d %H:%M:%S")
    with gt.lock:
        gt.open()

        # Send stop command
        _, _ = gt.stop()
        time.sleep(0.15)

        # Verify actual state
        ok_op, op_raw = gt.op_status()
        op_text = op_raw.decode(errors="replace")

        ok = ("OP S" in op_text) or ("OP STOP" in op_text)

        gt.stop_reader()

    return JSONResponse({
        "ok": ok and ok_op,
        "at": at
    })

# =========================
# OUTDOOR TEMP WEBSOCKET (unchanged)
# =========================

async def fetch_outdoor_temp_c() -> float | None:
    try:
        async with httpx.AsyncClient(timeout=5) as client:
            r = await client.get(OPEN_METEO_URL)
            r.raise_for_status()
            data = r.json()
            return float(data["current_weather"]["temperature"])
    except Exception:
        return None

@app.websocket("/ws")
async def ws(websocket: WebSocket):
    await websocket.accept()
    while True:
        temp = await fetch_outdoor_temp_c()
        await websocket.send_json({"temperature": temp})
        await asyncio.sleep(10)
